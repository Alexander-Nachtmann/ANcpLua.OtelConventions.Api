<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet config for the Nuke build project.

  The Nuke.OpenTelemetry.Conventions shared component package is published to the
  O-ANcppLua GitHub Packages NuGet feed (https://nuget.pkg.github.com/O-ANcppLua/index.json).
  Restoring from CI uses GITHUB_TOKEN automatically; local restore needs a PAT with
  read:packages exported as %GITHUB_PACKAGES_TOKEN% (consumed by the env-var section
  in the user's ~/.nuget/NuGet/NuGet.Config, or via `dotnet nuget add source` once).

  The legacy local-path source is kept as a fallback so a clean checkout of
  Nuke.OpenTelemetry.Conventions next to this repo continues to work for offline dev.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="github-O-ANcppLua"
         value="https://nuget.pkg.github.com/O-ANcppLua/index.json"
         protocolVersion="3" />
    <add key="local-nuke-otel-conventions"
         value="../../Nuke.OpenTelemetry.Conventions/src/Nuke.OpenTelemetry.Conventions/bin/Release" />
    <add key="nuget.org"
         value="https://api.nuget.org/v3/index.json"
         protocolVersion="3" />
  </packageSources>
  <packageSourceCredentials>
    <github-O-ANcppLua>
      <add key="Username" value="%GITHUB_ACTOR%" />
      <add key="ClearTextPassword" value="%GITHUB_PACKAGES_TOKEN%" />
    </github-O-ANcppLua>
  </packageSourceCredentials>
</configuration>
