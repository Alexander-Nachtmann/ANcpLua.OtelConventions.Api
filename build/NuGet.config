<?xml version="1.0" encoding="utf-8"?>
<!--
  Local-only NuGet config for the Nuke build project.
  Points at the locally-built Nuke.OpenTelemetry.Conventions package.
  The path is relative to this `build/` directory.
  Replace `local-nuke-otel-conventions` with a real feed once the package is published.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="local-nuke-otel-conventions"
         value="../../Nuke.OpenTelemetry.Conventions/src/Nuke.OpenTelemetry.Conventions/bin/Release" />
    <add key="nuget.org"
         value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
