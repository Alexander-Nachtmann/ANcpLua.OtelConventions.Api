<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet config for the Nuke build project.

  Nuke.OpenTelemetry.Conventions ships from the O-ANcppLua GitHub Packages NuGet feed
  (https://nuget.pkg.github.com/O-ANcppLua/index.json). Credentials come from the env
  vars below — set by GitHub Actions automatically via secrets.GITHUB_TOKEN, or for
  offline dev export GITHUB_ACTOR + GITHUB_PACKAGES_TOKEN (a PAT with read:packages)
  before invoking ./build.sh.

  For working against an uncommitted local build of Nuke.OpenTelemetry.Conventions,
  opt in via `dotnet nuget add source` against build/NuGet.config (do not commit).
  NuGet rejects nonexistent local sources at restore time with NU1301, which is why
  the local fallback is intentionally not committed here.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="github-O-ANcppLua"
         value="https://nuget.pkg.github.com/O-ANcppLua/index.json"
         protocolVersion="3" />
    <add key="nuget.org"
         value="https://api.nuget.org/v3/index.json"
         protocolVersion="3" />
  </packageSources>
  <packageSourceCredentials>
    <github-O-ANcppLua>
      <add key="Username" value="%GITHUB_ACTOR%" />
      <add key="ClearTextPassword" value="%GITHUB_PACKAGES_TOKEN%" />
    </github-O-ANcppLua>
  </packageSourceCredentials>
</configuration>
