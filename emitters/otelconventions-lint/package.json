{
  "name": "@ancplua/typespec-otelconventions-lint",
  "version": "0.1.0",
  "description": "TypeSpec library that lints ANcpLua-owned telemetry attributes against OTel semconv.",
  "type": "module",
  "main": "dist/index.js",
  "tspMain": "lib/main.tsp",
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "prepare": "tsc -p .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.12.0-dev"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@typespec/compiler": "1.12.0-dev.12",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  }
}
