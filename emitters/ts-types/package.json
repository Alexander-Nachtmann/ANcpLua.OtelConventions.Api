{
  "name": "@ancplua/typespec-emit-ts-types",
  "version": "0.1.0",
  "description": "ANcpLua TypeSpec emitter for TypeScript types (branded scalars + interfaces)",
  "type": "module",
  "main": "dist/index.js",
  "tspMain": "lib/main.tsp",
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "prepare": "tsc -p ."
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.12.0-dev"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "@typespec/compiler": "1.12.0-dev.12",
    "typescript": "5.9.3"
  }
}
